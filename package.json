{
  "name": "fixturepin",
  "version": "0.1.0",
  "description": "Pin fixture integrity manifests so quiet test fixture drift gets caught early.",
  "type": "module",
  "homepage": "https://github.com/rogerchappel/fixturepin#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/fixturepin.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/fixturepin/issues"
  },
  "bin": {
    "fixturepin": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist/src",
    "docs",
    "scripts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/tests/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm test && npm run check && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "fixtures",
    "testing",
    "integrity",
    "manifest",
    "cli",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "typescript": "^5.8.3"
  }
}
